# URL da interface web que o container WebView deve abrir.
OFP_WEB_APP_URL=https://seu-endereco/app
OFP_DRIVE_TOKEN_FOLDER_ID=
OFP_TOKEN_SECRET=
OFP_TOKEN_FILE_NAME=acesso.token

# Configuração Firebase Web (pública) usada pelo app WebView.
OFP_FIREBASE_API_KEY=
OFP_FIREBASE_AUTH_DOMAIN=
OFP_FIREBASE_DATABASE_URL=https://oficinapescasystem-default-rtdb.firebaseio.com/
OFP_FIREBASE_PROJECT_ID=
OFP_FIREBASE_STORAGE_BUCKET=
OFP_FIREBASE_MESSAGING_SENDER_ID=
OFP_FIREBASE_APP_ID=

# Canal lógico compartilhado entre Desktop e APK para comandos/realtime.
OFP_FIREBASE_SYNC_CHANNEL=global
